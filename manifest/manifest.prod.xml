<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- PRODUCTION manifest (FREE build). New GUID so dev + prod can be sideloaded
       side by side. SourceLocation points at the GitHub Pages PROJECT site for
       the Glean_add-in repo. Build/deploy: .github/workflows/deploy-addin.yml.
       The post-UFIT upgrade is a SEPARATE manifest variant that adds the Entra
       WebApplicationInfo + Graph scopes; the free build needs none of that. -->
  <Id>5fc5aef8-f083-44bf-8c90-86331a609273</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>UF DTSC Lab</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Local Glean"/>
  <Description DefaultValue="FERPA-safe email assistant for the UF community. All data stays in your own UF M365 account."/>
  <IconUrl DefaultValue="https://goshtasbsh.github.io/Glean_add-in/assets/icon-80.png"/>
  <HighResolutionIconUrl DefaultValue="https://goshtasbsh.github.io/Glean_add-in/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://goshtasbsh.github.io/Glean_add-in/"/>
  <AppDomains>
    <AppDomain>https://goshtasbsh.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.10"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://goshtasbsh.github.io/Glean_add-in/index.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.10">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Url"/>
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="msgReadOpenPaneButton">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url"/>
                      <SupportsPinning>true</SupportsPinning>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://goshtasbsh.github.io/Glean_add-in/assets/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://goshtasbsh.github.io/Glean_add-in/assets/icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://goshtasbsh.github.io/Glean_add-in/assets/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://goshtasbsh.github.io/Glean_add-in/index.html"/>
          <bt:Url id="Taskpane.Url" DefaultValue="https://goshtasbsh.github.io/Glean_add-in/index.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Local Glean"/>
          <bt:String id="TaskpaneButton.Label" DefaultValue="Open Local Glean"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Local Glean pane to summarize, label, and draft replies for this message."/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
